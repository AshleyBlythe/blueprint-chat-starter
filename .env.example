# Example environment file for blueprint-chat-starter
#
# Copy this file to `.env` and fill in values if you want to run the app
# without pasting keys into the UI every time.
#
#   cp .env.example .env
#
# IMPORTANT:
#   - `.env` is git-ignored. NEVER commit a real `.env` with real keys.
#   - This starter is for local/personal/educational use.
#   - Providing keys here is OPTIONAL. By default you paste your key in the
#     UI (BYOK) and it is sent to the local backend for that request only.

# Port the local backend proxy listens on (optional).
PORT=8787

# Optional fallback API keys. If a key is NOT sent from the UI, the backend
# will fall back to the matching key below. Leave blank to require BYOK.
# Do NOT commit real values.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
